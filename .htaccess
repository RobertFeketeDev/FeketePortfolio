<IfModule mod_rewrite.c>
    RewriteEngine On

    # Ha a kért URL egy létező fájl vagy mappa a public-on belül (pl. stilus.css, kep.jpg), 
    # akkor azt közvetlenül szolgálja ki az Apache, ne nyúljon hozzá.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Minden más esetben irányítsunk át mindent a public/index.php fájlra, 
    # és fűzzük hozzá a kért útvonalat az 'url' paraméterhez.
    RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
</IfModule>